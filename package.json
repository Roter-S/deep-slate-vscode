{
  "name": "deep-slate",
  "displayName": "Deep Slate",
  "description": "A dark theme with deep blue-gray tones",
  "version": "0.0.3",
  "publisher": "Roter-S",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "slate",
    "blue",
    "gray"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Deep Slate",
        "uiTheme": "vs-dark",
        "path": "./themes/deep-slate-color-theme.json"
      }
    ],
    "configurationDefaults": {
      "editor.fontFamily": "'Cascadia Code', 'Cascadia Mono', Consolas, monospace",
      "editor.fontLigatures": "'calt', 'ss01'",
      "editor.fontSize": 13.5,
      "editor.lineHeight": 23,
      "editor.fontWeight": "500"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Roter-S/deep-slate-vscode"
  },
  "icon": "images/icon.png",
  "license": "MIT"
}
